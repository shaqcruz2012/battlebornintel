# ============================================================
# BattleBornIntel — environment variable reference
# ============================================================
# Copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# This file is read by:
#   - agents/src/config.py    (Python agents)
#   - api/src/config.js       (Node.js API server)
#   - docker-compose.yml      (PostgreSQL container)
#
# REQUIRED  = application will not start (or will error) without this value
# OPTIONAL  = safe default is used when absent; override as needed


# ── Database ──────────────────────────────────────────────────────────────────

# Password for the PostgreSQL 'bbi' user, used by docker-compose when
# initialising the container. Must match the password in DATABASE_URL.
# OPTIONAL — defaults to bbi_dev_password (change in production)
POSTGRES_PASSWORD=bbi_dev_password

# Full PostgreSQL connection string consumed by both the API and the agents.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# The default points to the docker-compose service on host port 5433.
# REQUIRED — the API server exits with a fatal error if this is unset
# (unless NODE_ENV=test, which skips the check).
DATABASE_URL=postgresql://bbi:bbi_dev_password@localhost:5433/battlebornintel


# ── API server ────────────────────────────────────────────────────────────────

# TCP port the Node.js API server listens on.
# OPTIONAL — defaults to 3001
API_PORT=3001

# Node environment. Controls logging verbosity, error detail, and whether the
# DATABASE_URL presence check is enforced at startup.
# Values: development | production | test
# OPTIONAL — defaults to development
NODE_ENV=development

# Secret key required for admin-only API endpoints (e.g. materialized view
# refresh triggered by agents). Pass as the X-Admin-Key HTTP header.
# OPTIONAL — defaults to null, which disables admin endpoints
# ADMIN_API_KEY=change-me-before-deploying


# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL the Vite frontend uses to reach the API server.
# OPTIONAL — defaults to http://localhost:3001
VITE_API_URL=http://localhost:3001


# ── Agent / AI services ───────────────────────────────────────────────────────

# Anthropic API key for Claude model calls made by the Python agents.
# Obtain from https://console.anthropic.com/
# REQUIRED for running agents — agents will produce no output if left empty
ANTHROPIC_API_KEY=sk-ant-xxx

# Base URL of the BattleBornIntel API, used by agents that write enrichment
# results back through the internal REST API.
# OPTIONAL — defaults to http://localhost:3001
API_BASE_URL=http://localhost:3001

# FRED (Federal Reserve Economic Data) API key for the economic-indicators
# ingestor agent. Fetches macro series: fedfunds, unrate, gdpc1, nvrgsp, etc.
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
# OPTIONAL — FRED ingestion is skipped when this is absent or empty
FRED_API_KEY=
